# MongoDB connection string
MONGO_URL=mongodb://localhost:27017/tzu-chat

# JWT Secret for token signing
JWT_SECRET=your_jwt_secret_here

# Port to run the server on
PORT=4040

# Client URLs for CORS
LOCAL_CLIENT_URL=http://localhost:5173
PROD_CLIENT_URL=https://your-production-app.vercel.app

# Transactional email (SMTP via nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password
EMAIL_FROM="Tzu Chat <no-reply@example.com>"
